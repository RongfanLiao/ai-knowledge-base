# ============================================================
# AI 知识库 V4 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# === LLM 配置（继承 V3，V4 沿用 LLM_* 统一命名） ===
# 支持任何 OpenAI 兼容 API：DeepSeek / Qwen / 智谱 / OpenAI 本身
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# === 成本控制 ===
PRICE_INPUT_PER_MILLION=1.0
PRICE_OUTPUT_PER_MILLION=2.0

# === Planner 策略（决定每次流水线的采集量和审核严格度） ===
# lite (1-9)：5 条，快速验证
# standard (10-19)：10 条，日常运行
# full (20+)：20 条，深度分析
PLANNER_TARGET_COUNT=10

# === GitHub API（用于采集） ===
GITHUB_TOKEN=ghp_your-github-token

# === Telegram Bot (V4 新增) ===
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# === 飞书 Bot (V4 新增) ===
FEISHU_APP_ID=cli_aa8f8f7aad775bb5
FEISHU_APP_SECRET=06Zu6Oi3q6gU1R3G8gMiPe6NvYrm7GMW
FEISHU_VERIFICATION_TOKEN=zr1nDtBGicByZCLcqVmOPbiFBQz8oSN7
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/ab8d56bd-925c-4ead-b383-ca8aba00a4ff
# 飞书交互机器人监听端口
FEISHU_BOT_PORT=9000

# === OpenClaw 网关配置 ===
OPENCLAW_PORT=3000

# === Docker 部署配置 ===
DOCKER_REGISTRY=registry.example.com
IMAGE_TAG=latest
DEPLOY_HOST=
DEPLOY_USER=deploy
DEPLOY_DIR=/opt/ai-knowledge-base

# === 时区 ===
TZ=Asia/Singapore
